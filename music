/*************************
 * HELPER: HIDE BOTH PLAYERS CLEANLY
 *************************/
function hideAllPlayers(stopAudio = true) {
    // YouTube
    if (youtubeIframe) {
        youtubeIframe.style.display = "none";

        if (stopAudio) {
            youtubeIframe.src = "";
        }
    }

    // Local video
    if (localVideo) {
        localVideo.style.display = "none";

        if (stopAudio) {
            localVideo.pause();
            localVideo.removeAttribute("src");
            localVideo.load();
        }
    }
}



/*************************
 * PLAYBACK FUNCTIONS
 *************************/
function playYoutubeLoop(youtubeLink) {
    ensureIframe();

    if (!youtubeLink || youtubeLink.trim() === '') {
        youtubeIframe.src = '';
        youtubeIframe.style.display = 'none';
        return;
    }

    let videoId = null;
    if (youtubeLink.includes('youtube.com/watch?v=')) {
        videoId = youtubeLink.split('v=')[1].split('&')[0];
    } else if (youtubeLink.includes('youtube.com/shorts/')) {
        videoId = youtubeLink.split('shorts/')[1].split('&')[0];
    } else if (youtubeLink.includes('youtu.be/')) {
        videoId = youtubeLink.split('youtu.be/')[1].split(/[?&]/)[0];
    }

    if (!videoId) {
        alert('Please provide a valid YouTube link.');
        return;
    }

    youtubeIframe.src =
        `https://www.youtube.com/embed/${videoId}?autoplay=1&loop=1&playlist=${videoId}&enablejsapi=1&origin=${location.origin}`;
    youtubeIframe.style.display = "block";
}

function pauseYoutubeAudio() {
    if (youtubeIframe) {
        youtubeIframe.contentWindow.postMessage(
            '{"event":"command","func":"pauseVideo","args":""}', '*'
        );
    }
}

function playYoutubeAudio() {
    if (youtubeIframe) {
        youtubeIframe.contentWindow.postMessage(
            '{"event":"command","func":"playVideo","args":""}', '*'
        );
    }
}

function adjustYoutubeVolume(value) {
    if (youtubeIframe) {
        youtubeIframe.contentWindow.postMessage(
            `{"event":"command","func":"setVolume","args":[${value * 100}]}`, '*'
        );
    }
}

/*************************
 * PLAYLIST LOGIC
 *************************/
function addLocalVideoToPlaylist(url, title, playNow) {
    const item = {
        link: url,
        title: title || "Local Video",
        isLocal: true
    };
    playlist.push(item);
    renderPlaylist();

    if (playNow) {
        currentIndex = playlist.length - 1;
        playCurrent();
    }
}

function addToPlaylist(link, title, playNow) {
    const item = {
        link,
        title: title || link,
        isLocal: false
    };
    playlist.push(item);
    renderPlaylist();

    if (playNow) {
        currentIndex = playlist.length - 1;
        playCurrent();
    }
}

// FIXED: playCurrent() now cleanly switches between players
function playCurrent() {
    if (currentIndex < 0 || currentIndex >= playlist.length) return;

    const item = playlist[currentIndex];

hideAllPlayers(true); // explicit stop only when switching tracks



    if (item.isLocal) {
        localVideo.src = item.link;
        localVideo.style.display = "block";
        localVideo.volume = youtubeVolume / 100;
        localVideo.play();
    } else {
        playYoutubeLoop(item.link);
    }

    highlightCurrentPlaylistItem();
}

function playNext() {
    if (!playlist.length) return;
    currentIndex = (currentIndex + 1) % playlist.length;
    playCurrent();
}

function playPrev() {
    if (!playlist.length) return;
    currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
    playCurrent();
}

function renderPlaylist() {
    playlistContainer.innerHTML = '';
    playlist.forEach((item, index) => {
        var row = document.createElement('div');
        row.style.display = 'flex';
        row.style.alignItems = 'center';
        row.style.justifyContent = 'space-between';
        row.style.padding = '3px 0';
        row.style.fontSize = '13px';
        row.style.cursor = 'pointer';

        var titleSpan = document.createElement('span');
        titleSpan.textContent = item.title || (item.isLocal ? "Local Video" : "YouTube Video");
        titleSpan.style.flex = '1';
        titleSpan.style.marginRight = '6px';
        titleSpan.style.whiteSpace = 'nowrap';
        titleSpan.style.overflow = 'hidden';
        titleSpan.style.textOverflow = 'ellipsis';

        var removeBtn = document.createElement('button');
        removeBtn.textContent = '×';
        removeBtn.style.width = '20px';
        removeBtn.style.height = '20px';
        removeBtn.style.borderRadius = '50%';
        removeBtn.style.border = 'none';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.background = '#444';
        removeBtn.style.color = '#fff';

        // FIXED: Proper removal logic (stops playback + revokes URL + fixes index)
        removeBtn.onclick = function(e) {
            e.stopPropagation();

            const removed = playlist[index];

            // Stop playback if removing current item
            if (index === currentIndex) {
                hideAllPlayers();
            }

            // Revoke object URL for local files
            if (removed.isLocal) {
                URL.revokeObjectURL(removed.link);
            }

            playlist.splice(index, 1);

            // Adjust currentIndex safely
            if (index < currentIndex) {
                currentIndex--;
            } else if (index === currentIndex) {
                currentIndex = Math.min(currentIndex, playlist.length - 1);
                if (currentIndex >= 0) playCurrent();
            }

            renderPlaylist();
        };

        row.onclick = function() {
            currentIndex = index;
            playCurrent();
        };

        row.appendChild(titleSpan);
        row.appendChild(removeBtn);
        playlistContainer.appendChild(row);
    });
    highlightCurrentPlaylistItem();
}

function highlightCurrentPlaylistItem() {
    const children = playlistContainer.children;
    for (let i = 0; i < children.length; i++) {
        children[i].style.background = (i === currentIndex) ? '#222' : 'transparent';
    }
}


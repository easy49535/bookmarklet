function searchYouTube(query) {
    if (!YT_API_KEY || !query.trim()) return;

    const url = `https://www.googleapis.com/youtube/v3/search?part=snippet&type=video&maxResults=5&q=${encodeURIComponent(query)}&key=${YT_API_KEY}`;

    fetch(url)
        .then(res => res.json())
        .then(data => {
            autocompleteList.innerHTML = '';
            if (!data.items || !data.items.length) {
                autocompleteList.style.display = 'none';
                return;
            }
            data.items.forEach(item => {
                const videoId = item.id.videoId;
                const title = item.snippet.title;

                var opt = document.createElement('div');
                opt.style.padding = '4px 6px';
                opt.style.cursor = 'pointer';
                opt.style.fontSize = '13px';
                opt.style.borderBottom = '1px solid #333';
                opt.textContent = title;

                opt.onmouseenter = () => opt.style.background = '#222';
                opt.onmouseleave = () => opt.style.background = 'transparent';
                opt.onclick = () => {
                    autocompleteList.style.display = 'none';
                    addToPlaylist(`https://www.youtube.com/watch?v=${videoId}`, title, true);
                    youtubeInput.value = '';
                };
                autocompleteList.appendChild(opt);
            });
            autocompleteList.style.display = 'block';
        })
        .catch(() => autocompleteList.style.display = 'none');
}

youtubeInput.addEventListener('input', function() {
    const val = youtubeInput.value.trim();
    if (val === '' || val.startsWith('http')) {
        autocompleteList.style.display = 'none';
        return;
    }
    searchYouTube(val);
});

youtubeInput.addEventListener('keydown', function(event) {
    if (event.key === 'Enter') {
        const val = youtubeInput.value.trim();
        if (val === '') return;
        if (val.startsWith('http')) {
            addToPlaylist(val, null, true);
            youtubeInput.value = '';
        } else {
            searchYouTube(val);
        }
    }
});

searchButton.onclick = () => {
    const val = youtubeInput.value.trim();
    if (val && !val.startsWith('http')) searchYouTube(val);
};

loadButton.onclick = () => {

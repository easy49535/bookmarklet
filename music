// FIXED: Toggle now properly hides both players when closing
function toggleMusicPlayer() {
    isMusicPlayerVisible = !isMusicPlayerVisible;
    musicPlayerContainer.style.display = isMusicPlayerVisible ? "block" : "none";

    if (!isMusicPlayerVisible) {
        // Hide visuals, keep audio if option enabled
        hideAllPlayers(!KEEP_AUDIO_WHEN_HIDDEN);
    } else if (currentIndex >= 0) {
        // Restore visuals only
        if (youtubeIframe) youtubeIframe.style.display = "block";
        if (localVideo && playlist[currentIndex]?.isLocal) {
            localVideo.style.display = "block";
        }
    }
}



function toggleCollapse() {
    if (expandedHeight === null) {
        expandedHeight = musicPlayerContainer.offsetHeight;
    }

    if (!isCollapsed) {
        musicPlayerContainer.style.height = headerBar.offsetHeight + 'px';
        musicPlayerContainer.style.overflow = 'hidden';
        musicPlayerContainer.style.opacity = '0.9';
        isCollapsed = true;
        collapseBtn.textContent = '+';
    } else {
        musicPlayerContainer.style.height = expandedHeight + 'px';
        musicPlayerContainer.style.overflow = 'visible';
        musicPlayerContainer.style.opacity = '1';
        isCollapsed = false;
        collapseBtn.textContent = '–';
    }
}

